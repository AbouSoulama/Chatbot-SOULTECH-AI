GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini
LOCALAI_API_KEY=
LOCALAI_BASE_URL=http://localhost:8080/v1
LOCALAI_MODEL=llama-3.1-8b-instruct
AI_PROVIDER=groq
WA_CLIENT_ID=main
SKIP_WHATSAPP_INIT=0
WA_COUNTRY_CODE=225
WA_NOTIFY_COUNSELOR=1
CHROME_EXECUTABLE_PATH=
OCR_LANG=fra+eng
# Auth dashboard (sessions)
# En production: mets un secret long et aléatoire
SESSION_SECRET=change_me_in_production
# 1 = inscription autorisée, 0 = inscription désactivée
ALLOW_REGISTER=1
# Découpe des réponses WhatsApp (plusieurs bulles, délai aléatoire entre min et max)
REPLY_CHUNK_MIN_SENTENCES=2
REPLY_CHUNK_MAX_SENTENCES=3
REPLY_CHUNK_DELAY_MIN_MS=5000
REPLY_CHUNK_DELAY_MAX_MS=6000
